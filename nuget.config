<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      INTERIM local feed for the Andy.Data / Andy.Data.Abstractions prerelease packages, which are not
      yet published to nuget.org. Build them with:  dotnet pack ../andy-data/src/Andy.Data.Abstractions
      and ../andy-data/src/Andy.Data  -c Release -o ../andy-data/nupkg -p:Version=<ver>
      Once Andy.Data is published to nuget.org, delete this source (nuget.org will resolve it).
      The path is relative to this file and assumes andy-data is a sibling of andy-tools.
    -->
    <add key="andy-data-local" value="../andy-data/nupkg" />
  </packageSources>
</configuration>
